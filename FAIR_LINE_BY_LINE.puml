@startuml 

left to right direction
skinparam packageStyle rectangle

skinparam usecase {
  BorderColor black
  FontSize 13
  BackgroundColor white
}

actor Trainer
actor "Other trainers\ntraining coordinator,\ntraining event organiser" as OT
actor Learner


rectangle "Minimum steps to make FAIR training materials\nbased on community experience" {

(Develop training materials) as START

(Make Findable) as F_MAIN #d0e2ff
(Make Accessible) as A_MAIN #d9f2d9
(Make Interoperable) as I_MAIN #fff4cc
(Make Reusable) as R_MAIN #f8d7da

START <--> F_MAIN
F_MAIN <--> A_MAIN
A_MAIN <--> I_MAIN
I_MAIN <--> R_MAIN

Trainer <--> START

' ===== FINDABILITY =====
(Use community metadata standards discovered through\nresources like FAIRsharing\nF2) as F1 #d0e2ff
(Use Bioschemas training\nprofile\nF2) as F2 #d0e2ff
(Deposit in Zenodo\nassign DOI to the materials and\nORCID for the trainers\nF1/F3) as F3 #d0e2ff
(Register materials in TeSS\nF4) as F4 #d0e2ff
(Annotation of training materials in TeSS\ne.g. domain-specific ontologies and descriptors) as F5 #d0e2ff
(Adding other annotation\ne.g. EDAM or bio.tools annotations) as F6 #d0e2ff
(Link datasets, workflows, materials via DOI\nF1, I3) as F7 #fff4cc

F_MAIN <--> F1
F1 ..> F2 : <<extend>>
F2 --> F4
F1 --> F3
F3 --> F4
F4 --> F5 : <<include>>
F6 <--> F5 : <<extend>>


' ===== ACCESSIBILITY =====
(Provide details of the access in the metadata\nrestricted or open\nA1.1) as A1 #d9f2d9
(Provide details of authentication\nand authorisation if needed e.g. LMS\nA1.2) as A2 #d9f2d9
(Ensure metadata remains\naccessible through open-access repositories\nA2/F1) as A3 #d9f2d9

A_MAIN --> A1
A1 --> A2 
A2 --> A3


' ===== INTEROPERABILITY =====
(Develop materials using\ninteroperable platforms e.g. GitHub\nI1/R) as I1 #fff4cc
(Use community lesson templates:\nCarpentries, ELIXIR\nI2/R) as I2 #fff4cc
(Use FAIR vocabularies discovered via\nFAIRsharing\nI2) as I3 #fff4cc
(For LMS, package content using\nLMS standards\nI3) as I5 #fff8dc

I_MAIN <--> I1
I1 ..> I2 : <<include>>
I2 ..> I3 : <<include>>
I3 ..> F7 : <<include>>
F7 ..> I5 : <<extend>>


' ===== REUSABILITY =====
(Provide clear and\naccessible license details\nin the metadata\nR1.1) as R1 #f8d7da
(Track provenance withrich metadata e.g\nversioning through GitHub with PID through Zenodo\nR1.2/I3) as R2 #f8d7da
(Add citation metadata using CITATION.cff or\ncontributers role through CRediT taxonomy\nR1.2, F3) as R5 #f8d7da
(Use community and\ndomain standards discovered via FAIRsharing\nR1.3/I2) as R4 #f8d7da

R_MAIN --> R1
R1 --> R2
R2 -->R5 : <<extend>>
R2 --> R4

' ===== USER SIDE =====
(Search materials via TeSS\nF) as U1 #d0e2ff
(Access via links in metadata as\nin Zenodo or LMS\nA) as U2 #d9f2d9


Learner <--> U1
U1 <--> U2
U2 <--> R_MAIN
OT <--> R_MAIN
OT <--> I_MAIN
OT <--> F4
}

@enduml
